{
  "name": "dalnex-hrms",
  "version": "0.1.0",
  "private": true,
  "description": "Dalnex HRMS — attendance & payroll admin portal (Next.js + TypeScript + Supabase)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:types": "supabase gen types typescript --local > src/types/database.ts",
    "seed:users": "node --env-file=.env.local scripts/seed-users.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "exceljs": "^4.4.0",
    "next": "^15.5.20",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.5.20",
    "supabase": "^2.2.1",
    "typescript": "^5.7.3"
  }
}
